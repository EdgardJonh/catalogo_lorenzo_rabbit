# =============================================================================
# Supabase — copia este archivo como .env.local y completa los valores.
# Dashboard: https://supabase.com → tu proyecto → Project Settings → API
# =============================================================================

# URL del proyecto (se usa en cliente y servidor)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave "anon" / "public" — va al navegador; no des permisos de admin por RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave "service_role" — SOLO servidor (rutas /api/*, nunca NEXT_PUBLIC_*).
# Necesaria para CRUD admin, uploads y operaciones que bypassan RLS con cuidado.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Bucket de Storage para fotos de conejitos (opcional; por defecto: conejos)
SUPABASE_BUCKET=conejos
